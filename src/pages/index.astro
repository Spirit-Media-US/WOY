---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Work On Yourself">
	<main class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
		<div class="max-w-2xl">
			<!-- Mark -->
			<div class="mb-12">
				<div
					class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full border border-[--color-amber-accent]/30 bg-[--color-warm-100]"
				>
					<span class="font-[--font-heading] text-2xl font-semibold text-[--color-amber-deep]"
						>W</span
					>
				</div>
			</div>

			<!-- Title -->
			<h1
				class="font-[--font-heading] text-4xl font-medium tracking-tight text-[--color-slate-deep] sm:text-5xl md:text-6xl"
			>
				Work On Yourself
			</h1>

			<!-- Tagline -->
			<p class="mx-auto mt-6 max-w-lg text-lg leading-relaxed text-[--color-slate-soft] sm:text-xl">
				A formation-centered Soul Care Intensive for leaders whose outer success has outpaced
				their inner life.
			</p>

			<!-- Divider -->
			<div class="mx-auto my-10 h-px w-24 bg-[--color-amber-accent]/40"></div>

			<!-- Description -->
			<p class="mx-auto max-w-md text-base leading-relaxed text-[--color-slate-soft]">
				Pastorally stewarded. Relationally grounded. Theologically centered on restoration to
				God as Father.
			</p>

			<!-- Contact -->
			<div class="mt-12">
				<a
					href="mailto:kevin@workonyourself.com"
					class="inline-block border-b border-[--color-amber-accent]/50 pb-0.5 text-sm font-semibold uppercase tracking-widest text-[--color-amber-deep] transition-colors hover:border-[--color-amber-accent] hover:text-[--color-amber-accent]"
				>
					Begin the Conversation
				</a>
			</div>

			<!-- Footer -->
			<p class="mt-16 text-xs tracking-wide text-[--color-slate-soft]/60">
				&copy; {new Date().getFullYear()} Work on Yourself LLC
			</p>
		</div>
	</main>
</Layout>
