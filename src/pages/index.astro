---
import { PortableText } from 'astro-portabletext';
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity';

// Fetch site settings
const siteSettingsQuery = `*[_type == "siteSettings"][0] {
  siteName,
  tagline,
  defaultMetaDescription,
  companyLegalName,
  heroHeadline,
  heroSubtext,
  heroImage,
  aboutKevin,
  kevinPhoto,
  email,
  phone,
  applicationUrl,
  facebook,
  instagram,
  youtube
}`;

const testimonialQuery = `*[_type == "testimonial"] | order(order asc, _createdAt desc) {
  _id,
  quote,
  name,
  role,
  photo,
  featured,
  order
}`;

const siteSettings = await sanityClient.fetch(siteSettingsQuery);
const testimonials = await sanityClient.fetch(testimonialQuery);

// All required fields come directly from Sanity with no hardcoded fallbacks
const title = siteSettings.siteName;
const description = siteSettings.defaultMetaDescription;
const heroHeadline = siteSettings.heroHeadline;
const heroSubtext = siteSettings.heroSubtext;
const applicationUrl = siteSettings.applicationUrl;
const companyLegalName = siteSettings.companyLegalName;
const heroImageUrl = siteSettings?.heroImage ? urlFor(siteSettings.heroImage).url() : null;
const kevinPhotoUrl = siteSettings?.kevinPhoto ? urlFor(siteSettings.kevinPhoto).url() : null;
---

<Layout title={title} description={description}>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "Work On Yourself",
			"url": "https://workonyourself.com",
			"description": description,
			"founder": { "@type": "Person", "name": "Kevin White" },
			"areaServed": "Worldwide",
			"serviceType": ["Coaching", "Personal Development", "Leadership Training"]
		})}></script>
	</Fragment>
	<main class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
		<div class="max-w-2xl">
			<!-- Hero Image -->
			{heroImageUrl && (
				<div class="mb-8 rounded-lg overflow-hidden shadow-lg">
					<img 
						src={heroImageUrl} 
						alt={heroHeadline}
						class="w-full h-auto object-cover"
					/>
				</div>
			)}

			<!-- Mark -->
			<div class="mb-12">
				<div
					class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full border border-[--color-amber-accent]/30 bg-[--color-warm-100]"
				>
					<span class="font-[--font-heading] text-2xl font-semibold text-[--color-amber-deep]"
						>W</span
					>
				</div>
			</div>

			<!-- Title -->
			<h1
				class="font-[--font-heading] text-4xl font-medium tracking-tight text-[--color-slate-deep] sm:text-5xl md:text-6xl"
			>
				{heroHeadline}
			</h1>

			<!-- Tagline -->
			<p class="mx-auto mt-6 max-w-lg text-lg leading-relaxed text-[--color-slate-soft] sm:text-xl">
				{heroSubtext}
			</p>

			<!-- Divider -->
			<div class="mx-auto my-10 h-px w-24 bg-[--color-amber-accent]/40"></div>

			<!-- Description -->
			{siteSettings?.aboutKevin ? (
				<div class="mx-auto max-w-md text-base leading-relaxed text-[--color-slate-soft] prose prose-sm">
					<PortableText value={siteSettings.aboutKevin} />
				</div>
			) : null}

			<!-- Kevin Photo -->
			{kevinPhotoUrl && (
				<div class="mt-8 mb-8">
					<div class="mx-auto w-32 h-32 rounded-full overflow-hidden shadow-md">
						<img 
							src={kevinPhotoUrl} 
							alt="Kevin"
							class="w-full h-full object-cover"
						/>
					</div>
				</div>
			)}

			<!-- Contact -->
			<div class="mt-12">
				<a
					href={applicationUrl}
					class="inline-block border-b border-[--color-amber-accent]/50 pb-0.5 text-sm font-semibold uppercase tracking-widest text-[--color-amber-deep] transition-colors hover:border-[--color-amber-accent] hover:text-[--color-amber-accent]"
				>
					Begin the Conversation
				</a>
			</div>

			<!-- Testimonials Section -->
			{testimonials && testimonials.length > 0 && (
				<div class="mt-20">
					<h2 class="font-[--font-heading] text-2xl font-medium text-[--color-slate-deep] mb-8">
						Voices of Transformation
					</h2>
					<div class="space-y-8 max-w-xl mx-auto">
						{testimonials.slice(0, 3).map((testimonial: any) => (
							<blockquote class="border-l-2 border-[--color-amber-accent]/40 pl-6">
								<p class="text-base italic leading-relaxed text-[--color-slate-soft] mb-4">
									"{testimonial.quote}"
								</p>
								<footer class="text-sm font-semibold text-[--color-slate-deep]">
									— {testimonial.name}
									{testimonial.role && (
										<span class="block text-xs text-[--color-slate-soft] font-normal">
											{testimonial.role}
										</span>
									)}
								</footer>
							</blockquote>
						))}
					</div>
				</div>
			)}

			<!-- Footer -->
			<p class="mt-16 text-xs tracking-wide text-[--color-slate-soft]/60">
				&copy; {new Date().getFullYear()} {companyLegalName}
			</p>
		</div>
	</main>
</Layout>
