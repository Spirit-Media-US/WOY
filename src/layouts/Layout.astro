---
import { sanityClient, urlFor } from '../lib/sanity';

interface Props {
	title: string;
	description?: string;
	noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;

// Fetch siteSettings to get dynamic siteName
const siteSettingsQuery = `*[_type == "siteSettings"][0] {
  siteName,
  defaultMetaDescription,
  heroImage
}`;

const siteSettings = await sanityClient.fetch(siteSettingsQuery);
const siteName = siteSettings.siteName;
const defaultDescription = siteSettings.defaultMetaDescription;
// Use passed description if provided, otherwise use site default
const finalDescription = description || defaultDescription;
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const ogImageUrl = siteSettings?.heroImage
	? urlFor(siteSettings.heroImage).width(1200).height(630).url()
	: null;
const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={finalDescription} />
		<meta name="generator" content={Astro.generator} />

		<!-- Open Graph -->
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={finalDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:url" content={canonicalUrl} />
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		{noindex && <meta name="robots" content="noindex" />}

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Source+Sans+3:ital,wght@0,300;0,400;0,600;0,700;1,400&display=swap"
			rel="stylesheet"
		/>

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{fullTitle}</title>

		<!-- Google Analytics GA4 -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-W3R21TNHTX"></script>
		<script>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-W3R21TNHTX');
		</script>
	</head>
	<body
		class="min-h-screen font-[--font-body] text-[--color-slate-deep] bg-[--color-cream] antialiased"
	>
		<slot />
	</body>
</html>

<style is:global>
	@import '../styles/global.css';
</style>
